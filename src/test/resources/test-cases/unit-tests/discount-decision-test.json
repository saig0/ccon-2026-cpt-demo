{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Should calculate discount - loyalty 5+ robots",
      "description": "With 6 previously purchased robots and 2 in the order, the 5+ loyalty discount of 25% applies.",
      "instructions": [
        {
          "type": "EVALUATE_DECISION",
          "decisionDefinitionSelector": {
            "decisionDefinitionId": "discount"
          },
          "variables": {
            "numberOfPreviouslyPurchasedRobots": 6,
            "numberOfRobotsInOrder": 2,
            "numberOfUpgradesInOrder": 0
          }
        },
        {
          "type": "ASSERT_DECISION",
          "decisionSelector": {
            "decisionDefinitionId": "discount"
          },
          "output": 25
        }
      ]
    },
    {
      "name": "Should calculate discount - loyalty 3+ robots",
