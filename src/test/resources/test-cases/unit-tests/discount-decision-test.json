{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Should calculate discount - loyalty 5+ robots (10 purchased)",
      "description": "Loyalty: 5+ robots. With 10 previously purchased robots and 1 in the order, the 25% loyalty discount applies.",
      "instructions": [
        {
          "type": "EVALUATE_DECISION",
          "decisionDefinitionSelector": {
            "decisionDefinitionId": "discount"
          },
          "variables": {
            "numberOfPreviouslyPurchasedRobots": 10,
            "numberOfRobotsInOrder": 1,
            "numberOfUpgradesInOrder": 0
          }
        },
        {
          "type": "ASSERT_DECISION",
          "decisionSelector": {
            "decisionDefinitionId": "discount"
          },
          "output": 25
        }
      ]
    },
