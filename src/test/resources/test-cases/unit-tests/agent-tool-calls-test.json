{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Should reply to user with agent message and receive user reply",
      "description": "The agent activates the send-agent-reply tool which sends a message to the user and waits for the reply. The job worker is verified by the local task variable 'message' set by the input mapping.",
      "instructions": [
        {
          "type": "MOCK_JOB_WORKER_COMPLETE_JOB",
          "jobType": "send-chat-message"
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "variables": {
            "userName": "Luke",
            "message": "I have an issue with my robot.",
            "conversationId": "conversation-1"
          },
          "startInstructions": [
            {
              "elementId": "customer-support-agent"
            }
          ],
          "runtimeInstructions": [
            {
              "type": "TERMINATE_PROCESS_INSTANCE",
              "afterElementId": "customer-support-agent"
            }
          ]
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "elementId": "customer-support-agent"
          },
          "activateElements": [
            {
              "elementId": "send-agent-reply",
              "variables": {
                "toolCall": {
                  "agentReply": "Hi Luke, I see that you have two robots: R2-D2 and C3P0. Which one are you having issues with?"
                }
              }
            }
          ]
        },
        {
          "type": "ASSERT_VARIABLES",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "elementSelector": {
            "elementId": "send-agent-reply"
          },
          "variables": {
            "message": "Hi Luke, I see that you have two robots: R2-D2 and C3P0. Which one are you having issues with?"
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE_MESSAGE_SUBSCRIPTION",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "messageSelector": {
            "messageName": "user-message",
            "correlationKey": "conversation-1"
          },
          "state": "IS_WAITING"
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "user-message",
          "correlationKey": "conversation-1",
          "variables": {
            "message": "It's C3P0. He doesn't stop talking."
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "elementSelector": {
            "elementId": "customer-support-agent#innerInstance"
          },
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_VARIABLES",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "variables": {
            "toolCallResult": "It's C3P0. He doesn't stop talking."
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "state": "IS_ACTIVE"
        }
      ]
    },
