    {
      "name": "Should calculate discount based on the decision table",
      "description": "The agent activates the calculate-discount tool. The job worker is verified by the local task variables set by the input mapping (numberOfPreviouslyPurchasedRobots, numberOfRobotsInOrder, numberOfUpgradesInOrder).",
      "instructions": [
        {
          "type": "MOCK_DMN_DECISION",
          "decisionDefinitionId": "discount",
          "variables": {
            "discount": 15
          }
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "variables": {
            "userName": "Luke",
            "message": "I have an issue with my robot.",
            "conversationId": "conversation-1"
          },
          "startInstructions": [
            {"elementId": "customer-support-agent"}
          ],
          "runtimeInstructions": [
            {"type": "TERMINATE_PROCESS_INSTANCE", "afterElementId": "customer-support-agent"}
          ]
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "elementId": "customer-support-agent"
          },
          "activateElements": [
            {
              "elementId": "calculate-discount",
              "variables": {
                "toolCall": {
                  "numberOfPreviouslyPurchasedRobots": 2,
                  "numberOfRobotsInOrder": 1,
                  "numberOfUpgradesInOrder": 0
                }
              }
            }
          ]
        },
        {
          "type": "ASSERT_VARIABLES",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "elementSelector": {"elementId": "calculate-discount"},
          "variables": {
            "numberOfPreviouslyPurchasedRobots": 2,
            "numberOfRobotsInOrder": 1,
            "numberOfUpgradesInOrder": 0
          }
        }
      ]
    },
    {
      "name": "Should call the order process as a child process",
      "description": "The agent activates the order-items tool which calls the order process. The job worker is verified by the local task variable 'orderRequest' set by the input mapping.",
      "instructions": [
        {
          "type": "MOCK_CHILD_PROCESS",
          "processDefinitionId": "order-process",
          "variables": {
            "order": {
              "id": 42,
              "shipmentAddress": {
                "street": "1 Moisture Farm Rd",
                "city": "Anchorhead",
                "country": "Tatooine"
              },
              "paymentAmount": 9999.99,
              "items": [],
              "status": "PREPARED_FOR_SHIPPING"
            }
          }
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "variables": {
            "userName": "Luke",
            "message": "I have an issue with my robot.",
            "conversationId": "conversation-1"
          },
          "startInstructions": [
            {"elementId": "customer-support-agent"}
          ],
          "runtimeInstructions": [
            {"type": "TERMINATE_PROCESS_INSTANCE", "afterElementId": "customer-support-agent"}
          ]
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": {
            "elementId": "customer-support-agent"
          },
          "activateElements": [
            {
              "elementId": "order-items",
              "variables": {
                "toolCall": {
                  "orderRequest": {
                    "customerId": 2,
                    "shipmentAddress": {
                      "street": "Moisture Farm, Jundland Wastes",
                      "city": "Tatooine",
                      "country": "Outer Rim Territories"
                    },
                    "paymentAmount": 9999.99,
                    "orderItems": [{"robotId": 1, "upgradeId": null, "quantity": 1}]
                  }
                }
              }
            }
          ]
        },
        {
          "type": "ASSERT_VARIABLES",
          "processInstanceSelector": {
            "processDefinitionId": "customer-support-agent-process"
          },
          "elementSelector": {"elementId": "order-items"},
          "variables": {
            "orderRequest": {
              "customerId": 2,
              "shipmentAddress": {
                "street": "Moisture Farm, Jundland Wastes",
                "city": "Tatooine",
                "country": "Outer Rim Territories"
              },
              "paymentAmount": 9999.99,
              "orderItems": [{"robotId": 1, "upgradeId": null, "quantity": 1}]
            }
          }
        },
        {
          "type": "ASSERT_VARIABLES",
          "processInstanceSelector": {
            "processDefinitionId": "order-process"
          },
          "variables": {
            "orderRequest": {
              "customerId": 2,
              "shipmentAddress": {
                "street": "Moisture Farm, Jundland Wastes",
                "city": "Tatooine",
                "country": "Outer Rim Territories"
              },
              "paymentAmount": 9999.99,
              "orderItems": [{"robotId": 1, "upgradeId": null, "quantity": 1}]
            }
          }
        }
      ]
    }
  ]
}
