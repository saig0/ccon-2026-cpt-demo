<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_15mo7ll" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="customer-support-agent-process" name="Customer support agent" isExecutable="true">
    <bpmn:adHocSubProcess id="customer-support-agent" name="Customer support agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="5" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="eu-central-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=10000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=&#34;You are **SupportAgent** of **Camunda Robotics**, a helpful, humorous, chat agent that can handle customer requests using any tools explicitly provided to you at runtime.&#10;&#10;If tools are provided, you should prefer them instead of guessing an answer. You can call the same tool multiple times by providing different input values. Don&#39;t guess any tools which were not explicitly configured. If no tool matches the request, try to generate an answer. If you&#39;re not able to find a good answer, return with a message stating why you&#39;re not able to.&#10;&#10;--------------------&#10;&#10;1. Check if the user is a known customer &#10;2. Use the customer database to load missing information and the order history&#10;3. Use the product catalog to offer new products or upgrades&#10;4. Use the knowledge database to help with problems&#10;5. Escalate to a human if you need help&#10;&#10;---------------------&#10;&#10;Wrap minimal, inspectable reasoning in *exactly* this XML template:&#10;&#10;&#60;thinking&#62;&#10;&#60;context&#62;…briefly state the customer’s need and current state…&#60;/context&#62;&#10;&#60;reflection&#62;…list candidate tools, justify which you will call next and why…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;Reveal **no** additional private reasoning outside these tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="={&#10;  userName: userName,&#10;  userRequest: userRequest&#10;}" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=20" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:input target="agent" />
          <zeebe:output source="=agent" target="customer_support_agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="errorExpression" value="=if error.code != null then&#10;  bpmnError(&#34;AGENT_ERROR&#34;, &#34;Error [&#34; + string(error.code) + &#34;]: &#34; + string(error.message), error)&#10;else&#10;  null" />
          <zeebe:header key="retryBackoff" value="PT30S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15xih2a</bpmn:incoming>
      <bpmn:outgoing>Flow_0aurxhe</bpmn:outgoing>
      <bpmn:serviceTask id="load-customer-data" name="Load customer data">
        <bpmn:documentation>Use this tool to load customer data and the order history.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.customerName, &#34;The name of the customer&#34;)" target="customerName" />
            <zeebe:output source="=customer" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:taskDefinition type="load-customer-data" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="load-product-catalog" name="Load product catalog">
        <bpmn:documentation>Use this tool to load the product catalog about available robots and upgrades.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="load-product-catalog" />
          <zeebe:ioMapping>
            <zeebe:output source="=products" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="search-knowledge-base" name="Search knowledge base">
        <bpmn:documentation>Use this tool to search the knowledge base about known problems and solutions.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="search-knowledge-base" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.keyword, &#34;The keyword to search for.&#34;)" target="keyword" />
            <zeebe:output source="=knowledgeBaseEntries" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:intermediateThrowEvent id="Event_08njjqe" name="Human escalation">
        <bpmn:incoming>Flow_0ebyntt</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1nywcxn" escalationRef="Escalation_0e1ro02" />
      </bpmn:intermediateThrowEvent>
      <bpmn:serviceTask id="send-agent-reply" name="Send agent reply">
        <bpmn:documentation>Use this tool to send a reply to the user</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="send-chat-message" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.agentReply, &#34;The message to reply. In HTML format with icons.&#34;)" target="message" />
            <zeebe:output source="=append(conversation, &#10;  {user: &#34;support-agent&#34;, message: message}&#10;)" target="conversation" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_1c80qxp</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:intermediateCatchEvent id="user-message-received" name="User message received">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=message" target="toolCallResult" />
            <zeebe:output source="=append(conversation, &#10;  {user: userName, message: message}&#10;)" target="conversation" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1c80qxp</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_1dv3gur" messageRef="Message_06m1mqc" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1c80qxp" sourceRef="send-agent-reply" targetRef="user-message-received" />
      <bpmn:serviceTask id="inform-user-about-escalation" name="Inform user about escalation">
        <bpmn:documentation>Use this tool to escalate to a human for taking over the coversation.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="send-chat-message" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.agentReply, &#34;The message to inform the user about the human escalation. Title the message with &#39;Human intervention&#39; to make clear that a human will continue the conversation. In HTML format with icons.&#34;)" target="message" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0ebyntt</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_0ebyntt" sourceRef="inform-user-about-escalation" targetRef="Event_08njjqe" />
      <bpmn:businessRuleTask id="calculate-discount" name="Calculate discount">
        <bpmn:documentation>Use this tool to calculate an order discount.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledDecision decisionId="discount" resultVariable="toolCallResult" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.numberOfPreviouslyPurchasedRobots, &#34;The number of previously purchased robots of the customer.&#34;, &#34;number&#34;)" target="numberOfPreviouslyPurchasedRobots" />
            <zeebe:input source="=fromAi(toolCall.numberOfRobotsInOrder, &#34;The number of robots in the order.&#34;, &#34;number&#34;)" target="numberOfRobotsInOrder" />
            <zeebe:input source="=fromAi(toolCall.numberOfUpgradesInOrder, &#34;The number of upgrades in the order.&#34;, &#34;number&#34;)" target="numberOfUpgradesInOrder" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:businessRuleTask>
      <bpmn:callActivity id="order-items" name="Order items">
        <bpmn:documentation>Use this tool to order items for the customer.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="order-process" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.orderRequest, &#34;The customer request to place a new order, including the customer ID, the destination address, the amount to pay, and the items of the order (robots, upgrades - Only with ID references).&#34;, &#34;object&#34;, { properties: { customerId: {type: &#34;number&#34;}, paymentAmount: {type: &#34;number&#34;}, shipmentAddress: {type: &#34;object&#34;, properties: {street: {type: &#34;string&#34;}, city: {type: &#34;string&#34;}, country: {type: &#34;string&#34;}}}, orderItems: {type: &#34;array&#34;, items: {type: &#34;object&#34;, properties: {robotId: {type: &#34;integer&#34;}, upgradeId: {type: &#34;integer&#34;}, quantity: {type: &#34;integer&#34;}} }} } })" target="orderRequest" />
            <zeebe:output source="=order" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:callActivity>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_15xih2a" sourceRef="StartEvent_1" targetRef="customer-support-agent" />
    <bpmn:startEvent id="StartEvent_1" name="New conversation">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=conversationId" target="conversationId" />
          <zeebe:output source="=userName" target="userName" />
          <zeebe:output source="=message" target="userRequest" />
          <zeebe:output source="=[&#10;  {user: userName, message: userRequest}&#10;]" target="conversation" />
          <zeebe:output source="={}" target="agent_context" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_15xih2a</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:boundaryEvent id="Event_0awr7ai" name="Human escalation" attachedToRef="customer-support-agent">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="={&#10;  escalation: {&#10;    followUp: &#34;By human&#34;&#10;  }&#10;}" target="customer_support_agent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1lzr9vc</bpmn:outgoing>
      <bpmn:escalationEventDefinition id="EscalationEventDefinition_0tbex2u" escalationRef="Escalation_0e1ro02" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0wq1cjd" name="Agent error" attachedToRef="customer-support-agent">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="={&#10;  error: {&#10;    code: code,&#10;    message: message&#10;  }&#10;}" target="customer_support_agent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1nqvwus</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1sp5c58" errorRef="Error_05qvyqa" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_0nnnt3i" name="After 1 hour" attachedToRef="customer-support-agent">
      <bpmn:outgoing>Flow_0ggrnzm</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1pjy0m5">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="analyze-conversation" name="Analyse conversation" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="eu-central-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=10000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=&#34;You are a judge agent who analyzes a conversation from a user and a support chat agent. Summarize the coversation, measure the performance of the agent, and give a recommendation for the human on how to follow-up.&#10;&#10;1. If the agent did not end the conversation properly, return the outcome &#39;AGENT_ERROR&#39;.&#10;2. If the agent ran into some error, return the outcome &#39;AGENT_ERROR&#39;.&#10;3. If the agent escalated to a human, return the outcome &#39;HUMAN_ESCALATION&#39;.&#10;4. If the agent responses was not good enough and should be improved, return the outcome &#39;AGENT_IMPROVEMENTS&#39;.&#10;5. Otherwise return the outcome &#39;OKAY&#39;.&#10;&#10;Return a JSON with the properties: `outcome`, `reasoning`, `summary`, and `recommendation`. The text should be in plain text format, no quotes, no tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Conversation: &#34; + string(conversation) + &#34;, Agent context: &#34; + string(customer_support_agent)" target="data.userPrompt.prompt" />
          <zeebe:input source="=final_judge_agent.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=true" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="final_judge_agent" />
          <zeebe:header key="resultExpression" value="={&#10;  conversation_outcome: response.responseJson.outcome,&#10;  reasoning: response.responseJson.reasoning,&#10;  conversation_summary: response.responseJson.summary,&#10;  recommendation: response.responseJson.recommendation&#10;}" />
          <zeebe:header key="retryBackoff" value="PT60S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0aurxhe</bpmn:incoming>
      <bpmn:incoming>Flow_13k83b5</bpmn:incoming>
      <bpmn:outgoing>Flow_0vb3t2g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0aurxhe" sourceRef="customer-support-agent" targetRef="analyze-conversation" />
    <bpmn:exclusiveGateway id="Gateway_0beapgz" default="Flow_0zjlis5">
      <bpmn:incoming>Flow_0vb3t2g</bpmn:incoming>
      <bpmn:outgoing>Flow_0zjlis5</bpmn:outgoing>
      <bpmn:outgoing>Flow_03eg1we</bpmn:outgoing>
      <bpmn:outgoing>Flow_1a1dxhb</bpmn:outgoing>
      <bpmn:outgoing>Flow_03whjw8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0vb3t2g" sourceRef="analyze-conversation" targetRef="Gateway_0beapgz" />
    <bpmn:endEvent id="Event_0flsbgi" name="Conversation ended">
      <bpmn:incoming>Flow_0zjlis5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0zjlis5" name="All fine" sourceRef="Gateway_0beapgz" targetRef="Event_0flsbgi" />
    <bpmn:sequenceFlow id="Flow_03eg1we" name="Agent error" sourceRef="Gateway_0beapgz" targetRef="report-error-to-user">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=conversation_outcome = "AGENT_ERROR"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1a1dxhb" name="Agent improvements" sourceRef="Gateway_0beapgz" targetRef="review-conversation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=conversation_outcome = "AGENT_IMPROVEMENTS"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="report-error-to-user" name="Report error to user">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-chat-message" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;&#60;p&#62;&#60;strong&#62;👤 Human escalation&#60;/strong&#62;&#60;/p&#62;&#10;  &#10;  &#60;p&#62;🤖 Oops, something went wrong. I’m handing you over to a real human.&#60;/p&#62;&#10;&#10;  &#60;p&#62;📧 One of our support agents will follow up with you via email shortly.&#60;/p&#62;&#10;&#10;  &#60;p&#62;💬 If your request is urgent, you can also reach us via our support hotline.&#60;/p&#62;&#10;&#10;  &#60;p&#62;❤️ Thanks for reaching out to us — we’ll be in touch soon.&#60;/p&#62;&#34;" target="message" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03eg1we</bpmn:incoming>
      <bpmn:outgoing>Flow_0imduyu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="human-intervention" name="Human intervention">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Human-review" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;http://localhost:3000/chat.html?id=&#34; + string(conversationId)" target="coversationLink" />
          <zeebe:input source="=conversationId" target="conversationId" />
          <zeebe:input source="=conversation_summary" target="conversation_summary" />
          <zeebe:input source="=recommendation" target="recommendation" />
        </zeebe:ioMapping>
        <zeebe:priorityDefinition priority="100" />
        <zeebe:taskSchedule followUpDate="=now() + @&#34;PT1M&#34;" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0imduyu</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:userTask id="review-conversation" name="Review conversation">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Human-review" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;http://localhost:3000/chat.html?id=&#34; + string(conversationId)" target="coversationLink" />
          <zeebe:input source="=conversationId" target="conversationId" />
          <zeebe:input source="=conversation_summary" target="conversation_summary" />
          <zeebe:input source="=recommendation" target="recommendation" />
        </zeebe:ioMapping>
        <zeebe:priorityDefinition priority="25" />
        <zeebe:taskSchedule followUpDate="= now() + @&#34;P7D&#34;" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1a1dxhb</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0imduyu" sourceRef="report-error-to-user" targetRef="human-intervention" />
    <bpmn:exclusiveGateway id="Gateway_0v9d8eg">
      <bpmn:incoming>Flow_1nqvwus</bpmn:incoming>
      <bpmn:incoming>Flow_0ggrnzm</bpmn:incoming>
      <bpmn:incoming>Flow_1lzr9vc</bpmn:incoming>
      <bpmn:outgoing>Flow_13k83b5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1nqvwus" sourceRef="Event_0wq1cjd" targetRef="Gateway_0v9d8eg" />
    <bpmn:sequenceFlow id="Flow_13k83b5" sourceRef="Gateway_0v9d8eg" targetRef="analyze-conversation" />
    <bpmn:sequenceFlow id="Flow_0ggrnzm" sourceRef="Event_0nnnt3i" targetRef="Gateway_0v9d8eg" />
    <bpmn:sequenceFlow id="Flow_1lzr9vc" sourceRef="Event_0awr7ai" targetRef="Gateway_0v9d8eg" />
    <bpmn:userTask id="human-escalation" name="Human escalation">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Human-intervention" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;http://localhost:3000/chat.html?id=&#34; + string(conversationId)" target="coversationLink" />
          <zeebe:input source="=conversationId" target="conversationId" />
          <zeebe:input source="=conversation_summary" target="conversation_summary" />
          <zeebe:input source="=recommendation" target="recommendation" />
        </zeebe:ioMapping>
        <zeebe:priorityDefinition priority="75" />
        <zeebe:taskSchedule followUpDate="=now() + @&#34;PT5M&#34;" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03whjw8</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_03whjw8" name="Human esclation" sourceRef="Gateway_0beapgz" targetRef="human-escalation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=conversation_outcome = "HUMAN_ESCALATION"</bpmn:conditionExpression>
