# Camunda connection settings (Camunda SaaS)
# Copy this file to .env and fill in your credentials

# Camunda SaaS cluster settings
ZEEBE_ADDRESS=your-cluster-id.zeebe.camunda.io:443
ZEEBE_CLIENT_ID=your-client-id
ZEEBE_CLIENT_SECRET=your-client-secret
ZEEBE_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token
ZEEBE_TOKEN_AUDIENCE=zeebe.camunda.io

# --- OR --- Self-managed Camunda (no auth required by default)
# ZEEBE_ADDRESS=localhost:26500
# ZEEBE_INSECURE_CONNECTION=true

# Chat server port (default: 3000)
PORT=3000
